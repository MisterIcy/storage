{
    "name": "mistericy/storage",
    "description": "Storage & File System Abstraction Library",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MisterIcy\\Storage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\MisterIcy\\Storage\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Alexandros Koutroulis",
            "email": "icyd3mon@gmail.com",
            "homepage": "https://mistericy.github.io",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/mistericy/storage/issues"
    },
    "suggest": {
        "aws/aws-sdk-php": "To enable AWS S3 Support"
    },
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "^9.6.34",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "infection/infection": "^0.32.6"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        },
        "audit": {
            "abandoned": "fail",
            "block-insecure": true
        },
        "platform": {
            "php": ">=8.0"
        }
    }
}
